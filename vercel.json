{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/competitors/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ]
}
